            },
            "tenancy": "default",
            "timeouts": null,
            "user_data": "#!/bin/bash\nset -e\n              \n# Update and install dependencies\napt update\napt install -y git curl python3-pip python3-venv\n              \n# Install Node.js\ncurl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -\napt install -y nodejs\n              \n# Clone repository\ncd /opt\ngit clone -b feat/main/strands-chat https://github.com/davidawcloudsecurity/learn-lovable-llm-chat.git app\ncd app/api/strands\n              \n# Create Python virtual environment\npython3 -m venv venv\nsource venv/bin/activate\n              \n# Install Python dependencies\npip install --upgrade pip\npip install -r requirements.txt\n              \n# Create .env file with AWS configuration\ncat \u003e .env \u003c\u003c'ENVFILE'\nPORT=8000\nAWS_DEFAULT_REGION=us-east-1\nMODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0\nCHAT_SESSIONS_TABLE_NAME=demo-project-ChatSessions\nENVFILE\n              \n# Install PM2 globally\nnpm install -g pm2\n              \n# Start the Python FastAPI server with PM2 using uvicorn\ncd /opt/app/api/strands\npm2 start /opt/app/api/strands/venv/bin/uvicorn \\\n  --name bedrock-api \\\n  --interpreter none \\\n  -- index:app --host 0.0.0.0 --port 8000\npm2 save\npm2 startup systemd -u root --hp /root\n\n",
            "user_data_base64": null,
            "user_data_replace_on_change": false,
            "volume_tags": null,
